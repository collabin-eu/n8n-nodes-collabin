{
  "name": "n8n-nodes-collabin",
  "version": "0.1.1",
  "description": "n8n community node for Collabin — manage leave requests, users, teams and calendars via the Collabin API, with a webhook trigger for real-time leave events.",
  "keywords": [
    "n8n-community-node-package",
    "collabin",
    "leave-management",
    "hr"
  ],
  "license": "MIT",
  "homepage": "https://collabin.eu",
  "author": {
    "name": "Collabin",
    "email": "support@collabin.eu"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/collabin-eu/n8n-nodes-collabin.git"
  },
  "bugs": {
    "url": "https://github.com/collabin-eu/n8n-nodes-collabin/issues"
  },
  "engines": {
    "node": ">=20.15"
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build && npm run lint -- -c .eslintrc.prepublish.js nodes credentials package.json"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/CollabinApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Collabin/Collabin.node.js",
      "dist/nodes/Collabin/CollabinTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "n8n-workflow": "^1.70.0",
    "prettier": "^3.3.2",
    "typescript": "^5.5.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
